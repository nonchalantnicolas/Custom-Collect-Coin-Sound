local table_insert = table.insert

local nicolas = {}
nicolas.__index = nicolas

function nicolas.new()
    return setmetatable({_tasks = {}, _destroyed = false}, nicolas)
end

function nicolas:GiveTask(task)
    if self._destroyed then
        self:_cleanupTask(task)
        return
    end
    table_insert(self._tasks, task)
    return task
end

function nicolas:GiveTasks(...)
    for _, task in ipairs({...}) do
        self:GiveTask(task)
    end
end

function nicolas:_cleanupTask(task)
    local taskType = typeof(task)
    if taskType == "RBXScriptConnection" then
        task:Disconnect()
    elseif taskType == "Instance" then
        task:Destroy()
    elseif taskType == "function" then
        task()
    elseif taskType == "table" and type(task.Destroy) == "function" then
        task:Destroy()
    end
end

function nicolas:DoCleaning()
    if self._destroyed then return end
    self._destroyed = true
    for _, task in ipairs(self._tasks) do
        self:_cleanupTask(task)
    end
    self._tasks = {}
end

function nicolas:Destroy()
    self:DoCleaning()
end

local RootNicolas = nicolas.new()
local shared = odh_shared_plugins

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local features = {
    enabled = false,
    soundId = "rbxassetid://7158356564",
    hasAppliedSound = false,
}

local connections = {}
local globalConnections = {}

local function cleanupConnections()
    for part, conn in pairs(connections) do
        conn:Disconnect()
    end
    connections = {}
    for _, conn in ipairs(globalConnections) do
        conn:Disconnect()
    end
    globalConnections = {}
end

local function replaceCoinSound(part)
    if not part then return end
    
    local function createReplacementSound(parent)
        local newSound = Instance.new("Sound")
        newSound.Name = "ReplacementSound"
        newSound.SoundId = features.soundId
        newSound.Volume = 1
        newSound.PlayOnRemove = false
        newSound.Parent = parent
        newSound:Play()
        
        newSound.Ended:Connect(function()
            newSound:Destroy()
        end)
        
        task.wait(2)
        if newSound.Parent and not newSound.IsPlaying then
            newSound:Destroy()
        end
    end
    
    local function processSound(sound)
        if sound:IsA("Sound") and sound.Name == "CoinSound" then
            if not sound:GetAttribute("Replaced") then
                sound.Volume = 0
                sound:SetAttribute("Replaced", true)
                
                if features.hasAppliedSound then
                    createReplacementSound(sound.Parent)
                end
            end
        end
    end
    
    if not connections[part] then
        local conn = part.ChildAdded:Connect(function(child)
            processSound(child)
        end)
        connections[part] = conn
    end
    
    for _, child in ipairs(part:GetChildren()) do
        processSound(child)
    end
end

local function monitorCharacter(character)
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        replaceCoinSound(hrp)
    end
    
    local charConn = character.ChildAdded:Connect(function(child)
        if child.Name == "HumanoidRootPart" and child:IsA("BasePart") then
            replaceCoinSound(child)
        end
    end)
    table_insert(globalConnections, charConn)
    
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            for _, sound in ipairs(part:GetChildren()) do
                if sound:IsA("Sound") and sound.Name == "CoinSound" then
                    if not sound:GetAttribute("Replaced") then
                        sound.Volume = 0
                        sound:SetAttribute("Replaced", true)
                        
                        if features.hasAppliedSound then
                            local newSound = Instance.new("Sound")
                            newSound.Name = "ReplacementSound"
                            newSound.SoundId = features.soundId
                            newSound.Volume = 1
                            newSound.PlayOnRemove = false
                            newSound.Parent = part
                            newSound:Play()
                            
                            newSound.Ended:Connect(function()
                                newSound:Destroy()
                            end)
                            
                            task.wait(2)
                            if newSound.Parent and not newSound.IsPlaying then
                                newSound:Destroy()
                            end
                        end
                    end
                end
            end
        end
    end
end

local function handlePlayer(player)
    if player.Character then
        monitorCharacter(player.Character)
    end
    
    local conn = player.CharacterAdded:Connect(function(character)
        monitorCharacter(character)
    end)
    table_insert(globalConnections, conn)
end

local function enablePlugin()
    cleanupConnections()
    
    for _, player in ipairs(Players:GetPlayers()) do
        handlePlayer(player)
    end
    
    local playerAddedConn = Players.PlayerAdded:Connect(handlePlayer)
    table_insert(globalConnections, playerAddedConn)
    
    if LocalPlayer.Character then
        monitorCharacter(LocalPlayer.Character)
    end
end

local function disablePlugin()
    cleanupConnections()
end

local function applySound()
    if features.enabled then
        features.hasAppliedSound = true
        disablePlugin()
        enablePlugin()
        shared.Notify("Custom coin sound applied!", 2)
    else
        shared.Notify("Enable the toggle first!", 2)
    end
end

local section = shared.AddSection("Custom Coin Sound")

section:AddParagraph("Side Notes", "Replaces the original collect coin sound with your own!\n\nCredits: @drowsynicolas")

section:AddToggle("Coin Sound Id", function(bool)
    features.enabled = bool
    if bool then
        features.hasAppliedSound = false
        enablePlugin()
    else
        features.hasAppliedSound = false
        disablePlugin()
    end
end)

section:AddTextBox("Enter sound ID (rbxassetid://...)", function(text)
    if text and text ~= "" then
        features.soundId = text
    end
end)

section:AddButton("Apply Custom Coin Sound", function()
    applySound()
end)

RootNicolas:GiveTask(function()
    features.enabled = false
    features.hasAppliedSound = false
    disablePlugin()
end)
